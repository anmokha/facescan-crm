# Email для получения заявок (Landing page)
RESEND_API_KEY=your_resend_api_key_here
NOTIFICATION_EMAIL=hello@yourdomain.com

# Gemini API для AI диагностики (Diagnostic Example /example)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Client SDK (Публичные ключи для браузера)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (Секретные ключи для сервера - Vercel Env Vars)
# Получить: Project Settings -> Service Accounts -> Generate New Private Key
# ВАЖНО: Весь текст ключа целиком, включая -----BEGIN PRIVATE KEY-----
FIREBASE_SERVICE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
FIREBASE_SERVICE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"

# Telegram Bot (Опционально)
TELEGRAM_BOT_TOKEN=your_bot_token

# Опционально: Google Sheets для бэкапа лидов
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_SPREADSHEET_ID=